// ClinicBook Assistant — scheduling core
// Multi-tenant from day one: every table hangs off Clinic so onboarding
// clinic #2 is a config row + adapter choice, not a schema change.

generator client {
  provider      = "prisma-client-js"
  // rhel-openssl-3.0.x matches Vercel's serverless function runtime (Amazon Linux).
  // Without this, Prisma can't find its query engine binary in production and
  // every DB call fails at runtime even though local dev works fine.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Set to Neon's pooled connection string in production (many short-lived
  // serverless invocations exhaust Postgres's connection limit otherwise);
  // directUrl is the unpooled one, used only for migrations. Point both at
  // the same local Postgres URL for local dev.
  directUrl = env("DIRECT_URL")
}

enum SlotStatus {
  OPEN
  BOOKED
  BLOCKED
}

// Full visit lifecycle, not just "booked or not": CONFIRMED (booked, patient
// hasn't arrived) -> CHECKED_IN (receptionist marks arrival) -> IN_PROGRESS
// (doctor started the consultation) -> COMPLETED (notes/prescription saved).
// AT_STAGE is an optional detour between CHECKED_IN and IN_PROGRESS: when the
// appointment's doctor's department has configured FlowSteps (see FlowStep),
// check-in lands here instead, and the patient sits in a shared department
// queue (Appointment.currentDepartmentId) until every stage is cleared, at
// which point it becomes CHECKED_IN as normal. Departments with no FlowSteps
// skip AT_STAGE entirely — check-in goes straight to CHECKED_IN as before.
// CANCELLED/NO_SHOW are terminal alternatives from CONFIRMED or CHECKED_IN.
enum AppointmentStatus {
  CONFIRMED
  CHECKED_IN
  AT_STAGE
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum UserRole {
  CLINIC_ADMIN
  RECEPTIONIST
  DOCTOR
  NURSE
  LAB
}

// Tracked from day one so the eventual payment integration has data to work
// with; not enforced yet (nothing blocks access when a trial lapses) since
// there's no way to pay to unblock until billing is wired up.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum Locale {
  AR
  EN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// Which EHR/scheduling system this clinic's data actually lives in.
// NATIVE = our own Postgres is the source of truth (MVP default).
enum IntegrationMode {
  NATIVE
  FHIR
  SHEETS
  CUSTOM_API
}

// Manual bookkeeping until real payment integration exists — a clinic logs
// what came in and what went out by hand, same as they'd track it on paper
// today. Once billing is wired up, completed/paid appointments could create
// INCOME transactions automatically instead.
enum TransactionType {
  INCOME
  EXPENSE
}

enum ChargeCategory {
  LAB
  PROCEDURE
  MEDICATION
  OTHER
}

// Which acquirer's terminal API pushes amounts to the physical POS device.
// MANUAL = staff charge the standalone terminal themselves and key in the
// approval code; the bank/PSP values are reserved for the planned terminal
// (ECR) integrations.
enum PosProvider {
  MANUAL
  GEIDEA
  NEOLEAP
}

enum PaymentMethod {
  POS_CARD
  CASH
}

// PENDING/FAILED only occur once a terminal API is wired in (amount pushed
// to the device, awaiting tap); manual recording always writes PAID.
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Clinic {
  id                    String             @id @default(cuid())
  name                  String
  address               String? // shown on printed prescriptions alongside the clinic name
  phone                 String? // shown on printed prescriptions alongside the clinic name
  receptionistName      String? // name the WhatsApp AI introduces itself as, e.g. "Sara" — null falls back to a generic role-based introduction
  timezone              String             @default("Asia/Riyadh")
  defaultLocale         Locale             @default(AR)
  isOpen24_7            Boolean            @default(false) // true = clinic operates 24/7, ignore openingTime/closingTime
  openingTime           String?            @default("08:00") // "HH:MM" format when isOpen24_7 is false
  closingTime           String?            @default("18:00") // "HH:MM" format when isOpen24_7 is false
  whatsappNumber        String?            @unique // null until the clinic configures WhatsApp
  // Per-clinic Meta WhatsApp Cloud API credentials — lets each clinic run
  // its own WhatsApp Business number/app instead of one global env-var
  // config. AccessToken/AppSecret are masked in the admin UI once set;
  // VerifyToken is server-generated and shown in plaintext for the admin
  // to paste into Meta's webhook config.
  whatsappPhoneNumberId String?
  whatsappAccessToken   String?
  whatsappAppSecret     String?
  whatsappVerifyToken   String?
  weekendDays           Int[]              @default([5, 6]) // Fri=5, Sat=6 (0=Sun..6=Sat)
  posProvider           PosProvider        @default(MANUAL)
  posTerminalName       String? // front-desk label for the physical terminal, e.g. "Front desk mada terminal"
  // Terminal-API credentials from the acquirer's merchant onboarding pack
  // (Geidea merchant portal / Neoleap merchant support). Same masking rules
  // as the WhatsApp credentials: key/secret are never echoed back to the
  // browser once saved. All null while posProvider = MANUAL.
  posMerchantId         String?
  posApiKey             String?
  posApiSecret          String?
  posTerminalId         String? // the physical device's terminal ID (printed on the terminal / its receipts)
  integrationMode       IntegrationMode    @default(NATIVE)
  integrationConfig     Json? // adapter-specific connection details
  trialEndsAt           DateTime
  subscriptionStatus    SubscriptionStatus @default(TRIALING)
  createdAt             DateTime           @default(now())

  users               User[]
  departments         Department[]
  doctors             Doctor[]
  patients            Patient[]
  appointments        Appointment[]
  conversations       Conversation[]
  transactions        Transaction[]
  escalations         StaffEscalation[]
  payments            Payment[]
  flowSteps           FlowStep[]
  labFieldDefinitions LabFieldDefinition[]
  waitlistEntries     Waitlist[]
  voiceNotes          VoiceNote[]
  auditLogs           AuditLog[]
}

model Transaction {
  id          String          @id @default(cuid())
  clinicId    String
  clinic      Clinic          @relation(fields: [clinicId], references: [id])
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  category    String?
  description String?
  occurredAt  DateTime
  createdAt   DateTime        @default(now())

  @@index([clinicId, occurredAt])
}

// A person who can log in — scoped to exactly one clinic and one role.
// Auth is passwordless (email OTP, see lib/auth.ts): whoever controls the
// email controls the account, there is no separate password to manage.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  doctorId  String?  @unique // set when role = DOCTOR, NURSE, or LAB — links to their Doctor (staff) row
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])
  photoUrl  String?  @db.Text // profile photo, stored as a data URL (see PhotoUploadField) — no external storage configured yet
  createdAt DateTime @default(now())

  paymentsRecorded Payment[]

  @@index([clinicId])
}

model OtpCode {
  id         String    @id @default(cuid())
  email      String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, code])
}

// Departments are how a clinic organizes doctors (e.g. "Dermatology",
// "General Medicine"). The AI receptionist matches a patient's natural-
// language request ("I need a skin doctor") against department names, not IDs.
// MEDICAL = a bookable specialty (Dental, General Medicine...), staffed by
// Doctor-role logins. NURSE/LAB = process-only stage departments, staffed by
// NURSE/LAB-role logins with their own dashboards (see NurseVisit, LabResult)
// — existing departments default to MEDICAL on migration and must be
// re-saved by the admin if they were actually acting as a Nurse/Lab stage.
enum DepartmentKind {
  MEDICAL
  NURSE
  LAB
}

model Department {
  id         String         @id @default(cuid())
  clinicId   String
  clinic     Clinic         @relation(fields: [clinicId], references: [id])
  name       String
  kind       DepartmentKind @default(MEDICAL)
  // false hides this department from patient-facing pickers (WhatsApp AI
  // booking + receptionist Booking tab) while it keeps working as a
  // FlowStep stage — for process-only departments like "Nurse" that
  // shouldn't be directly bookable by patients.
  isBookable Boolean        @default(true)
  createdAt  DateTime       @default(now())

  doctors                Doctor[]
  // FlowSteps this department OWNS, i.e. its own configured stage sequence
  // (see FlowStep.ownerDepartment).
  flowStepsAsOwner       FlowStep[]           @relation("FlowOwner")
  // FlowSteps where this department is an intermediate HANDLER for some
  // other department's sequence (see FlowStep.stageDepartment).
  flowStepsAsStage       FlowStep[]           @relation("FlowStage")
  currentForAppointments Appointment[]
  // Only populated when kind = LAB — the owner-defined result fields this
  // lab captures (see LabFieldDefinition).
  labFieldDefinitions    LabFieldDefinition[]
  labResults             LabResult[]

  @@unique([clinicId, name])
}

// One ordered step in a medical department's patient flow, configured from
// the admin "Flow" tab. Reception (before any FlowStep) and the assigned
// doctor (after the last FlowStep) are implicit — never stored here. A
// department with zero FlowStep rows keeps the original Reception -> Doctor
// behavior untouched.
model FlowStep {
  id                String     @id @default(cuid())
  clinicId          String
  clinic            Clinic     @relation(fields: [clinicId], references: [id])
  ownerDepartmentId String
  ownerDepartment   Department @relation("FlowOwner", fields: [ownerDepartmentId], references: [id])
  order             Int
  stageDepartmentId String
  stageDepartment   Department @relation("FlowStage", fields: [stageDepartmentId], references: [id])
  createdAt         DateTime   @default(now())

  @@unique([ownerDepartmentId, order])
  @@index([clinicId])
  @@index([stageDepartmentId])
}

model Doctor {
  id                String     @id @default(cuid())
  clinicId          String
  clinic            Clinic     @relation(fields: [clinicId], references: [id])
  departmentId      String
  department        Department @relation(fields: [departmentId], references: [id])
  name              String
  active            Boolean    @default(true)
  photoUrl          String?    @db.Text // profile photo, stored as a data URL (see PhotoUploadField) — no external storage configured yet
  // Live "at her desk" status shown to front desk — isAvailable is the
  // explicit on/off switch (set true at login, false at logout, or flipped
  // manually for a break); lastSeenAt is a heartbeat touched on every doctor
  // dashboard render (piggybacking the existing ~5s AutoRefresh poll) so a
  // browser tab closed without a clean logout goes stale on its own instead
  // of relying on unreliable unload-event detection.
  isAvailable       Boolean    @default(false)
  lastSeenAt        DateTime?
  // Consultation fee charged for appointments with this doctor
  consultationFee   Decimal    @default(0) @db.Decimal(10, 2)
  // Optional professional details
  qualifications    String? // e.g., "MBBS, MD Medicine, Fellowship"
  bio               String? // Professional biography
  specialization    String? // Medical specialization
  licenseNumber     String? // Medical license number
  yearsOfExperience Int? // Years in practice
  createdAt         DateTime   @default(now())

  workingHours  WorkingHours[]
  slots         Slot[]
  appointments  Appointment[]
  consultations Consultation[]
  // Populated only for staff whose department kind is NURSE/LAB respectively.
  nurseVisits     NurseVisit[]
  labResults      LabResult[]
  waitlistEntries Waitlist[]
  user            User? // set when a User with role=DOCTOR, NURSE, or LAB is linked to this staff record

  @@index([clinicId])
  @@index([departmentId])
}

// Recurring weekly template used to materialize Slot rows for a rolling window.
model WorkingHours {
  id                  String @id @default(cuid())
  doctorId            String
  doctor              Doctor @relation(fields: [doctorId], references: [id])
  dayOfWeek           Int // 0=Sun..6=Sat
  startTime           String // "09:00"
  endTime             String // "17:00"
  slotDurationMinutes Int    @default(20)

  @@index([doctorId])
}

// Materialized bookable slots for a rolling window (see slotGenerator).
// Unique constraint is the concurrency guard: two patients can never
// be assigned the same doctor+time.
model Slot {
  id       String     @id @default(cuid())
  doctorId String
  doctor   Doctor     @relation(fields: [doctorId], references: [id])
  startsAt DateTime
  endsAt   DateTime
  status   SlotStatus @default(OPEN)

  // Not a 1:1 back-relation: a slot can accumulate multiple CANCELLED/NO_SHOW
  // appointment rows over time (see Appointment.slotId's partial unique
  // index — only one non-terminal appointment per slot is enforced, not one
  // ever). Query the active one via Appointment.status when needed.
  appointments Appointment[]

  @@unique([doctorId, startsAt])
  @@index([doctorId, status, startsAt])
}

model Patient {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  phone        String // E.164, e.g. +9665XXXXXXXX
  name         String?
  email        String? // optional — set when a receptionist registers a walk-in with an email
  locale       Locale   @default(AR)
  // Doctor enters current age; we store the resulting birth year instead of
  // the raw age so it's always re-derived correctly on later visits without
  // anyone having to update it.
  birthYear    Int?
  gender       Gender?
  medicalNotes String? // allergies, chronic conditions, anything clinically relevant
  verified     Boolean  @default(false) // true after OTP verification for WhatsApp registrations
  // When we last sent this patient a "we miss you" re-engagement message —
  // the retention cron skips anyone contacted in the last 90 days so an
  // inactive patient is never spammed on every run.
  lastReEngagedAt DateTime?
  createdAt    DateTime @default(now())

  appointments    Appointment[]
  conversations   Conversation[]
  consultations   Consultation[]
  nurseVisits     NurseVisit[]
  labResults      LabResult[]
  prescriptions   Prescription[]
  waitlistEntries Waitlist[]
  voiceNotes      VoiceNote[]

  @@unique([clinicId, phone])
  @@index([clinicId, email])
}

model Appointment {
  id                  String            @id @default(cuid())
  clinicId            String
  clinic              Clinic            @relation(fields: [clinicId], references: [id])
  doctorId            String
  doctor              Doctor            @relation(fields: [doctorId], references: [id])
  patientId           String
  patient             Patient           @relation(fields: [patientId], references: [id])
  // Not @unique in Prisma — a cancelled appointment keeps its slotId forever
  // (history), so the same slot can accumulate several CANCELLED/NO_SHOW
  // rows. "At most one active appointment per slot" is instead enforced by
  // a partial unique index (see migration) that only covers non-terminal
  // statuses, so a freed slot can be rebooked without hitting a phantom
  // uniqueness conflict from its own cancelled history.
  slotId              String
  slot                Slot              @relation(fields: [slotId], references: [id])
  status              AppointmentStatus @default(CONFIRMED)
  reason              String? // free-text, logistics only (e.g. "follow-up") — never clinical advice
  bookedByStaff       Boolean           @default(false) // true for receptionist walk-ins, false for WhatsApp bookings
  checkedInAt         DateTime?
  startedAt           DateTime?
  reminderSentAt      DateTime?
  // Mirrors reminderSentAt's "don't contact twice" convention for the
  // retention cron's "sorry we missed you — rebook?" message after a NO_SHOW.
  noShowFollowUpSentAt DateTime?
  createdAt           DateTime          @default(now())
  // Set while status = AT_STAGE: which department's shared queue this
  // appointment currently sits in (see FlowStep). Null otherwise.
  currentDepartmentId String?
  currentDepartment   Department?       @relation(fields: [currentDepartmentId], references: [id])

  consultation Consultation?
  nurseVisit   NurseVisit?
  labResult    LabResult?
  charges      AppointmentCharge[]
  payments     Payment[]

  @@index([clinicId, status])
  @@index([slotId])
  @@index([currentDepartmentId])
}

// Money actually collected against an appointment (consultation fee plus
// any AppointmentCharges). Multiple rows per appointment allow split
// payments — e.g. part cash, part card on the POS terminal.
model Payment {
  id            String        @id @default(cuid())
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id])
  appointmentId String
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PAID)
  provider      PosProvider   @default(MANUAL) // which terminal API took this payment (MANUAL = keyed in by staff)
  providerTxnId String? // the acquirer's transaction id, used to poll status while PENDING
  failureReason String? // human-readable decline/timeout reason when status = FAILED
  reference     String? // POS approval code / receipt number from the terminal
  recordedById  String?
  recordedBy    User?         @relation(fields: [recordedById], references: [id])
  createdAt     DateTime      @default(now())

  @@index([clinicId, createdAt])
  @@index([appointmentId])
}

// Additional charges applied to an appointment (lab work, procedures, medications)
// on top of the base consultation fee
model AppointmentCharge {
  id            String         @id @default(cuid())
  appointmentId String
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  description   String // e.g., "Blood test", "Ultrasound"
  amount        Decimal        @db.Decimal(10, 2)
  category      ChargeCategory
  createdAt     DateTime       @default(now())

  @@index([appointmentId])
}

// A doctor's notes + prescription for one completed visit. Real clinical
// data — a step beyond the "logistics only" scope everything else here
// keeps to. Only reachable through the doctor's own scoped queries.
model Consultation {
  id                     String      @id @default(cuid())
  appointmentId          String      @unique
  appointment            Appointment @relation(fields: [appointmentId], references: [id])
  doctorId               String
  doctor                 Doctor      @relation(fields: [doctorId], references: [id])
  patientId              String
  patient                Patient     @relation(fields: [patientId], references: [id])
  notes                  String?
  prescription           String? // legacy text field; new prescriptions stored as Prescription rows
  weightKg               Float? // vital recorded at this visit, tracked over time on the patient's history page
  administeredTreatment  String? // meds/injections given on the spot by nurse or doctor — distinct from `prescription` (take-home)
  // When the doctor recommends "come back in N days" — we store the resulting
  // date (not the raw N) since that's what a reminder job would query
  // against. followUpReminderSentAt mirrors Appointment.reminderSentAt's
  // "don't remind twice" convention for a future WhatsApp reminder agent.
  followUpDate           DateTime?
  followUpReminderSentAt DateTime?
  createdAt              DateTime    @default(now())

  prescriptions Prescription[]

  @@index([patientId])
  @@index([doctorId])
  @@index([followUpDate])
}

// Structured medicine prescription with dosage, frequency, duration.
model Prescription {
  id              String       @id @default(cuid())
  consultationId  String
  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patientId       String
  patient         Patient      @relation(fields: [patientId], references: [id])
  medicineName    String // e.g., "Amoxicillin"
  dosage          String // e.g., "500mg"
  frequency       String // e.g., "3 times daily", "twice daily"
  durationDays    Int // total duration in days
  instructions    String? // special instructions (with food, before bed, etc.)
  dispensedAt     DateTime? // when patient got the medicine
  refillsRemaining Int      @default(0)
  expiryDate      DateTime?
  createdAt       DateTime @default(now())

  @@index([patientId, createdAt])
  @@index([consultationId])
}

// Vitals recorded by a NURSE-role staff member (a Doctor row whose
// department.kind = NURSE) while an appointment sits at their Flow stage —
// required before the appointment can advance (see nurseHandlers.ts).
model NurseVisit {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  nurseId       String
  nurse         Doctor      @relation(fields: [nurseId], references: [id])
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  bloodPressure String // e.g. "120/80" — free text, matches real charting shorthand
  heightCm      Float
  weightKg      Float
  temperatureC  Float?
  pulseBpm      Int?
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([patientId])
  @@index([nurseId])
}

enum LabFieldType {
  TEXT
  NUMBER
  TEXTAREA
  ATTACHMENT
}

// Owner-defined result field for one LAB-kind department (e.g. Blood Lab
// might define "Hemoglobin" NUMBER + "Notes" TEXTAREA; an X-Ray lab might
// define a single ATTACHMENT field) — configured on that department's
// admin edit page, replace-all-on-save (see saveLabFieldDefinitions).
model LabFieldDefinition {
  id           String       @id @default(cuid())
  clinicId     String
  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id])
  label        String
  fieldType    LabFieldType
  required     Boolean      @default(false)
  order        Int
  createdAt    DateTime     @default(now())

  values LabResultValue[]

  @@unique([departmentId, order])
  @@index([clinicId])
}

// One lab visit's captured results (see LabResultValue for the actual
// per-field values), recorded by a LAB-role staff member while the
// appointment sits at their Flow stage.
model LabResult {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  labStaffId    String
  labStaff      Doctor      @relation(fields: [labStaffId], references: [id])
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  createdAt     DateTime    @default(now())

  values LabResultValue[]

  @@index([patientId])
}

// One submitted value against one LabFieldDefinition. textValue holds
// TEXT/TEXTAREA/NUMBER (as a string) or an ATTACHMENT data URL alike.
// fieldDefinition has no cascade delete: removing a field definition that
// already has recorded values must fail loudly, not silently erase
// patient lab history (see saveLabFieldDefinitions).
model LabResultValue {
  id                String             @id @default(cuid())
  labResultId       String
  labResult         LabResult          @relation(fields: [labResultId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   LabFieldDefinition @relation(fields: [fieldDefinitionId], references: [id])
  textValue         String?            @db.Text

  @@unique([labResultId, fieldDefinitionId])
  @@index([fieldDefinitionId])
}

model Conversation {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  patientId     String?
  patient       Patient? @relation(fields: [patientId], references: [id])
  patientPhone  String
  state         Json     @default("{}") // scratch state for the orchestrator (pending slot choice, etc.)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages Message[]

  @@index([clinicId, patientPhone])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id])
  direction      MessageDirection
  body           String
  toolCalls      Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

enum EscalationStatus {
  OPEN
  RESOLVED
}

// A follow-up request the WhatsApp AI hands to the front desk (emergencies,
// complaints, billing questions, anything it can't book safely). Persisted so
// the AI's "staff will follow up" promise is actually backed by something a
// human sees — the receptionist dashboard shows OPEN rows as a queue.
model StaffEscalation {
  id           String           @id @default(cuid())
  clinicId     String
  clinic       Clinic           @relation(fields: [clinicId], references: [id])
  patientPhone String // E.164; patient name resolved at display time via Patient lookup
  reason       String
  urgent       Boolean          @default(false) // true = medical emergency flagged by the AI
  status       EscalationStatus @default(OPEN)
  createdAt    DateTime         @default(now())
  resolvedAt   DateTime?

  @@index([clinicId, status])
}

enum WaitlistStatus {
  WAITING // in line, not yet offered anything
  OFFERED // a freed slot was offered via WhatsApp, awaiting the patient's button reply
  FULFILLED // patient accepted an offered slot and was booked
  DECLINED // patient declined the offered slot (entry closed; they can re-join)
  EXPIRED // offer superseded (slot taken by someone else) or entry aged out
  CANCELLED // patient or staff removed the entry
}

// A patient waiting for an earlier/any slot with a doctor. When a booked
// slot is freed by a cancellation, the oldest WAITING entry for that doctor
// gets the slot offered over WhatsApp (accept/decline buttons) — see
// waitlistHandlers.ts. One offer is outstanding at a time per freed slot.
model Waitlist {
  id            String         @id @default(cuid())
  clinicId      String
  clinic        Clinic         @relation(fields: [clinicId], references: [id])
  patientId     String
  patient       Patient        @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  status        WaitlistStatus @default(WAITING)
  offeredSlotId String? // set while status = OFFERED
  offeredAt     DateTime?
  createdAt     DateTime       @default(now())

  @@index([clinicId, doctorId, status])
  @@index([patientId])
}

// A WhatsApp voice message from a patient. Only the provider's media id is
// stored — Meta media download URLs expire within minutes, so the audio is
// fetched on demand via the clinic's access token (see fetchMetaMediaUrl).
// transcript stays null until a speech-to-text integration fills it in.
model VoiceNote {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  patientId       String?
  patient         Patient? @relation(fields: [patientId], references: [id])
  patientPhone    String // E.164 — kept even when the phone isn't a registered patient yet
  providerMediaId String
  mimeType        String?
  transcript      String?
  createdAt       DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([patientId])
}

// Who touched which patient-identifiable data, and when — written by
// logAudit() from the server-action layer (patient search, reschedules,
// cancellations, history reads). Append-only; never exposed to patients.
model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  userId    String? // null for system/cron actions
  action    String // e.g. "patient.search", "appointment.cancel"
  entity    String // e.g. "Patient", "Appointment"
  entityId  String? // null for list/search actions
  detail    String? // e.g. the (masked) search query
  createdAt DateTime @default(now())

  @@index([clinicId, createdAt])
}

// Platform-wide (not per-clinic) setting controlling which design renders at
// "/". Always exactly one row, fixed id "global" — read on every request to
// "/", written only from the password-gated /landing_page console.
model LandingPageSetting {
  id        String   @id @default("global")
  variant   String   @default("classic") // "classic" | "animated"
  updatedAt DateTime @updatedAt
}
