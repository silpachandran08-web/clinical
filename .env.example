# --- Core ---
# Local dev: point both at the same local Postgres. On Vercel+Neon: DATABASE_URL
# is the pooled connection string, DIRECT_URL is the unpooled one (migrations only).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clinic_assistant"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/clinic_assistant"
PORT=8080

# --- AI ---
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-sonnet-5"

# --- WhatsApp provider: "meta" (fast, free, no approval — best for a friends trial)
# or "unifonic" (KSA BSP, needs business verification — switch to this when going live) ---
WHATSAPP_PROVIDER="meta"

# Meta Cloud API (Meta for Developers > your app > WhatsApp > API Setup)
META_PHONE_NUMBER_ID=""
META_ACCESS_TOKEN=""
META_VERIFY_TOKEN=""       # any string you choose; must match what you enter in the webhook config
META_APP_SECRET=""         # App dashboard > Settings > Basic. Used ONLY to verify webhook signatures.

# Unifonic (get from Unifonic dashboard once the WABA is provisioned — for going live in KSA)
UNIFONIC_APP_SID=""
UNIFONIC_SENDER_ID=""
UNIFONIC_API_BASE="https://api.unifonic.com"
UNIFONIC_WEBHOOK_SECRET=""

# Escalation: where to notify staff when the bot hands off to a human
STAFF_ESCALATION_WEBHOOK_URL=""
