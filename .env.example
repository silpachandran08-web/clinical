# --- Core ---
# Local dev: point both at the same local Postgres, or both at a Neon database
# (Neon is reachable from anywhere, so you don't need Postgres installed locally).
# On Vercel+Neon: DATABASE_URL is the pooled connection string, DIRECT_URL is
# the unpooled one (migrations only).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clinic_assistant"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/clinic_assistant"

# --- AI ---
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-haiku-4-5-20251001"

# --- Auth (passwordless — email one-time codes) ---
SESSION_SECRET="choose-a-long-random-string"

# EMAIL_PROVIDER="console" (default) logs the OTP code to server output instead of
# sending real email — free, no signup, and "09876" always works as the code in this
# mode so you can test with any email address. Switch to "resend" for production.
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- WhatsApp ---
# Meta credentials are NOT env vars — each clinic enters its own Phone Number
# ID / Access Token / App Secret from Admin > Clinic > "WhatsApp API
# credentials" once it's registered (per-clinic, not shared). See DEPLOY.md
# step 5.
#
# Unifonic (KSA BSP) remains a single global fallback provider, used only for
# clinics that haven't configured their own Meta credentials yet.
UNIFONIC_APP_SID=""
UNIFONIC_SENDER_ID=""
UNIFONIC_API_BASE="https://api.unifonic.com"
UNIFONIC_WEBHOOK_SECRET=""

# Escalation: where to notify staff when the bot hands off to a human
STAFF_ESCALATION_WEBHOOK_URL=""
